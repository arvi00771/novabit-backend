{
  "name": "@novabit/backend",
  "version": "0.1.0",
  "description": "NovaBit Exchange — Backend API (TypeScript + Fastify)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "start": "node dist/db/migrate.js up && node dist/app.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:up": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:reset": "tsx src/db/migrate.ts reset"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/postgres": "^6.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/redis": "^7.0.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@fastify/websocket": "^11.0.1",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "fastify-metrics": "^13.2.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.5.0",
    "otplib": "^12.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@typescript-eslint/rule-tester": "^8.26.0",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
